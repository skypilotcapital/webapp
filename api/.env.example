# SkyPilot Capital — webapp environment variables
# Copy this file to .env and fill in the values. Never commit .env to git.

# PostgreSQL connection
# On the droplet: DB_HOST=localhost (FastAPI is on the same machine as PostgreSQL)
# Local dev via SSH tunnel: DB_HOST=localhost (tunnel forwards 5432 to droplet)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=skypilot
DB_USER=skypilot_app
DB_PASSWORD=

# CORS — JSON list of allowed frontend origins
# Local dev only:
CORS_ORIGINS=["http://localhost:3000"]
# Production (add your Vercel URL here once deployed):
# CORS_ORIGINS=["https://your-app.vercel.app"]
